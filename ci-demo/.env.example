# ci-demo — environment for the real-agent harness (scripts/agent-run.mjs)
#
# Copy this file to `.env` and fill in the key(s) for the provider you want:
#
#     cp .env.example .env
#     # edit .env, then:
#     pnpm build && pnpm agent-run                # picks up .env automatically
#     pnpm agent-run -- --provider openai --repeats 3
#
# `.env` is gitignored — never commit real keys. Only agent-run.mjs reads these;
# the rest of the demo (cli / mcp / axi / token-diff / tests) is fully offline
# and needs no keys.
#
# Provider selection (agent-run.mjs): pass --provider explicitly, or let it
# auto-detect in this order —
#   1. OPENAI_API_KEY set        -> provider "openai"        (default model gpt-4o-mini)
#   2. ANTHROPIC_API_KEY set     -> provider "anthropic-api" (default model claude-sonnet-5)
#   3. neither set               -> provider "anthropic-cli" (your Claude Code
#                                   subscription; no key needed)

# --- OpenAI (cheap dev testing; gpt-4o-mini) --------------------------------
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Anthropic pay-as-you-go API (optional; exact per-token cost) -----------
# Leave unset to use your Claude Code subscription via `--provider anthropic-cli`.
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Optional overrides ------------------------------------------------------
# CI_DEMO_MODEL=gpt-4o-mini
